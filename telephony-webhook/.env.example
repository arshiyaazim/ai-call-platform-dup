# Server
PORT=3100

# PostgreSQL (uses the existing ai-postgres container)
DB_HOST=ai-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<your-postgres-password>
DB_NAME=postgres

# Dograh API (internal Docker network)
DOGRAH_API_URL=http://dograh-api:8000/api/v1

# Twilio (optional — signature validation disabled if empty)
TWILIO_AUTH_TOKEN=

# Webhook base URL (for signature verification)
WEBHOOK_BASE_URL=https://iamazim.com

# Logging
LOG_LEVEL=info
