# ============================================================
# Environment Configuration — AI Voice Agent SaaS Platform
# Domain: iamazim.com | VPS: 5.189.131.48
# ============================================================
# SETUP:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Generate secrets:        ./scripts/gen-secrets.sh
#   3. Validate:                ./scripts/gen-secrets.sh --check
#
# ROTATION:
#   Rotate all:       ./scripts/gen-secrets.sh --rotate-all
#   Rotate specific:  ./scripts/gen-secrets.sh --rotate FAZLE_JWT_SECRET,NEXTAUTH_SECRET
#
# See docs/secrets-rotation.md for details.
# ============================================================

# ── VPS / Infrastructure ────────────────────────────────────
VPS_IP=5.189.131.48

# ── Docker Registry ─────────────────────────────────────────
# REGISTRY=your-registry-here

# ── Domain ──────────────────────────────────────────────────
BACKEND_API_ENDPOINT=https://api.iamazim.com

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=postgres

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_SECRET

# ── MinIO (S3-compatible storage) ───────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ── JWT Secret ──────────────────────────────────────────────
OSS_JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN

# ── LiveKit (Real-time WebRTC Voice Streaming) ──────────────
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET_MIN_32_CHARS
LIVEKIT_WS_URL=wss://livekit.iamazim.com
LIVEKIT_WEBHOOK_URL=http://api:8000/api/v1/livekit/webhook

# ── TURN Server (WebRTC NAT traversal) ─────────────────────
TURN_HOST=turn.iamazim.com
TURN_SECRET=CHANGE_ME_TURN_SHARED_SECRET

# ── Grafana ────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Fazle Personal AI ──────────────────────────────────────
# REQUIRED: 64-char alphanumeric key to protect Fazle API
FAZLE_API_KEY=CHANGE_ME_64_CHAR_FAZLE_API_KEY

# JWT secret for Fazle user auth (min 32 chars)
# Also used as NEXTAUTH_SECRET inside fazle-ui container
FAZLE_JWT_SECRET=CHANGE_ME_FAZLE_JWT_SECRET_32_CHARS

# NextAuth.js (shares FAZLE_JWT_SECRET — kept for gen-secrets.sh compat)
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_32_CHARS
NEXTAUTH_URL=https://fazle.iamazim.com
FAZLE_NEXTAUTH_URL=https://fazle.iamazim.com
FAZLE_LIVEKIT_URL=wss://livekit.iamazim.com

# CORS — comma-separated origins accepted by Fazle services
ALLOWED_ORIGINS=https://fazle.iamazim.com,https://iamazim.com

# LLM provider: "openai" or "ollama"
FAZLE_LLM_PROVIDER=openai
FAZLE_LLM_MODEL=gpt-4o
FAZLE_OLLAMA_MODEL=llama3.1
FAZLE_OLLAMA_TIMEOUT=10

# LLM fallback (used by llm-gateway when primary provider fails)
FAZLE_FALLBACK_PROVIDER=openai
FAZLE_FALLBACK_MODEL=gpt-4o

# OpenAI API key (required when FAZLE_LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Web search API keys (at least one required for web intelligence)
SERPER_API_KEY=CHANGE_ME_SERPER_KEY
TAVILY_API_KEY=
FAZLE_SEARCH_PROVIDER=serper

# ── Fazle Voice (TTS) ─────────────────────────────────────
# Engine: "piper" (local, fast) or "elevenlabs" (cloud, premium)
FAZLE_VOICE_TTS_ENGINE=piper
FAZLE_VOICE_TTS_VOICE=alloy
FAZLE_VOICE_VOICE_MODEL=en_US-lessac-medium
FAZLE_VOICE_FAST_MODE=true
ELEVENLABS_VOICE_ID=

# ── Fazle Performance Tuning ──────────────────────────────
FAZLE_CACHE_TTL=300
PERSONA_CACHE_TTL=300
MEMORY_TOP_K=2

# Rate limiting
FAZLE_RATE_LIMIT_RPM=120
FAZLE_RATE_LIMIT_PER_IP_RPS=10
FAZLE_RATE_LIMIT_PER_USER_RPS=10

# Request batching (llm-gateway)
FAZLE_BATCH_WINDOW_MS=75
FAZLE_BATCH_MAX_SIZE=4

# ── Twilio (configure in Dograh UI → Settings → Telephony) ─
# Twilio credentials are stored in the database via the Dograh dashboard,
# NOT as env vars. dograh-api reads them from the `organization_configurations`
# table at runtime. The fields below are for reference only.
#
# Webhook URL (auto-configured by Dograh):
#   https://iamazim.com/telephony/inbound/{workflow_id}  (POST)
#   nginx proxies /telephony/ → dograh-api /api/v1/telephony/
#
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+447863767879

# ── ElevenLabs API (optional, required when TTS engine = elevenlabs)
# ELEVENLABS_API_KEY=your_key

# ── Tracing (optional) ─────────────────────────────────────
ENABLE_TRACING=false
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=

# ── Telemetry ──────────────────────────────────────────────
ENABLE_TELEMETRY=false

# ── UI Backend URL (internal Docker network) ───────────────
BACKEND_URL=http://api:8000

# ── Social Engine — WhatsApp + Facebook ─────────────────────
# Obtain credentials from Meta Developer Console.
# Use ONLY these canonical SOCIAL_* names — the compose stack
# expects them. Legacy WHATSAPP_* / FACEBOOK_* names are removed.

# Meta app secret — used for HMAC X-Hub-Signature-256 validation on webhook POST
SOCIAL_META_APP_SECRET=CHANGE_ME_META_APP_SECRET

# WhatsApp Cloud API (Business Platform)
SOCIAL_WHATSAPP_API_URL=https://graph.facebook.com/v19.0
SOCIAL_WHATSAPP_API_TOKEN=CHANGE_ME_WHATSAPP_API_TOKEN
SOCIAL_WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME_PHONE_NUMBER_ID

# Facebook Page integration
SOCIAL_FACEBOOK_PAGE_ACCESS_TOKEN=CHANGE_ME_FB_PAGE_ACCESS_TOKEN
SOCIAL_FACEBOOK_PAGE_ID=CHANGE_ME_FB_PAGE_ID

# Owner phone number (receives alerts / admin WhatsApp commands)
SOCIAL_OWNER_PHONE=

# Auto-generated by gen-secrets.sh — do not set manually
SOCIAL_ENCRYPTION_KEY=CHANGE_ME_SOCIAL_ENCRYPTION_KEY
SOCIAL_VERIFY_TOKEN=CHANGE_ME_SOCIAL_VERIFY_TOKEN
