# ============================================================
# Environment Configuration — AI Voice Agent SaaS Platform
# Domain: iamazim.com | VPS: 5.189.131.48
# ============================================================
# SETUP:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Generate secrets:        ./scripts/gen-secrets.sh
#   3. Validate:                ./scripts/gen-secrets.sh --check
#
# ROTATION:
#   Rotate all:       ./scripts/gen-secrets.sh --rotate-all
#   Rotate specific:  ./scripts/gen-secrets.sh --rotate FAZLE_JWT_SECRET,NEXTAUTH_SECRET
#
# See docs/secrets-rotation.md for details.
# ============================================================

# ── VPS / Infrastructure ────────────────────────────────────
VPS_IP=5.189.131.48

# ── Docker Registry ─────────────────────────────────────────
# REGISTRY=your-registry-here

# ── Domain ──────────────────────────────────────────────────
BACKEND_API_ENDPOINT=https://api.iamazim.com

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=postgres

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_SECRET

# ── MinIO (S3-compatible storage) ───────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ── JWT Secret ──────────────────────────────────────────────
OSS_JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN

# ── LiveKit (Real-time WebRTC Voice Streaming) ──────────────
LIVEKIT_API_KEY=CHANGE_ME_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=CHANGE_ME_LIVEKIT_SECRET_MIN_32_CHARS
LIVEKIT_WS_URL=wss://livekit.iamazim.com
LIVEKIT_WEBHOOK_URL=http://api:8000/api/v1/livekit/webhook

# ── TURN Server (WebRTC NAT traversal) ─────────────────────
TURN_HOST=turn.iamazim.com
TURN_SECRET=CHANGE_ME_TURN_SHARED_SECRET

# ── Grafana ────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Fazle Personal AI ──────────────────────────────────────
# REQUIRED: 64-char alphanumeric key to protect Fazle API
FAZLE_API_KEY=CHANGE_ME_64_CHAR_FAZLE_API_KEY

# JWT secret for Fazle user auth (min 32 chars)
FAZLE_JWT_SECRET=CHANGE_ME_FAZLE_JWT_SECRET_32_CHARS

# NextAuth.js secret (min 32 chars)
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_32_CHARS
NEXTAUTH_URL=https://fazle.iamazim.com
FAZLE_NEXTAUTH_URL=https://fazle.iamazim.com
FAZLE_LIVEKIT_URL=wss://livekit.iamazim.com

# LLM provider: "openai" or "ollama"
FAZLE_LLM_PROVIDER=openai
FAZLE_LLM_MODEL=gpt-4o
FAZLE_OLLAMA_MODEL=llama3.1

# OpenAI API key (required when FAZLE_LLM_PROVIDER=openai)
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# Web search API keys (at least one required for web intelligence)
SERPER_API_KEY=CHANGE_ME_SERPER_KEY
TAVILY_API_KEY=
FAZLE_SEARCH_PROVIDER=serper

# ── Twilio (configure in Dograh UI → Settings) ─────────────
# TWILIO_ACCOUNT_SID=your_sid
# TWILIO_AUTH_TOKEN=your_token

# ── ElevenLabs Voice Cloning (optional) ────────────────────
# ELEVENLABS_API_KEY=your_key

# ── Tracing (optional) ─────────────────────────────────────
ENABLE_TRACING=false
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=

# ── Telemetry ──────────────────────────────────────────────
ENABLE_TELEMETRY=false

# ── UI Backend URL (internal Docker network) ───────────────
BACKEND_URL=http://api:8000
